// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// FASE 1: Authentication & Users
enum UserRole {
  ADMIN      // Secretaría - full access
  PRECEPTOR  // Preceptor - limited access
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // bcrypt hashed
  name      String
  role      UserRole @default(PRECEPTOR)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// FASE 2: Domain Models - Educational System

// Student - Student information
model Student {
  id          String   @id @default(cuid())
  dni         String   @unique
  firstName   String
  lastName    String
  email       String?  @unique
  phone       String?
  address     String?
  birthDate   DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  enrollments Enrollment[]
  contributions Contribution[]

  @@map("students")
}

// Course - Course definition
model Course {
  id          String   @id @default(cuid())
  name        String
  description String?
  duration    Int      // duration in months
  price       Decimal  @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  periods CoursePeriod[]

  @@map("courses")
}

// CoursePeriod - Course instance for a specific period
model CoursePeriod {
  id             String   @id @default(cuid())
  courseId       String
  name           String   // e.g., "Basic Course - March 2025"
  startDate      DateTime
  endDate        DateTime
  monthlyPrice   Decimal @db.Decimal(10, 2)
  enabledMonths  Int[]   // Array of enabled months (1-12)
  year           Int      // Year for this period
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  course        Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrollments   Enrollment[]
  contributions Contribution[]
  invoices      CourseInvoice[]

  @@map("course_periods")
}

// Enrollment - Student enrollment in a course period
model Enrollment {
  id               String           @id @default(cuid())
  studentId        String
  coursePeriodId   String
  enrollmentDate   DateTime         @default(now())
  status           EnrollmentStatus @default(ACTIVE)
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Relations
  student       Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  coursePeriod  CoursePeriod  @relation(fields: [coursePeriodId], references: [id], onDelete: Cascade)

  // Unique constraint: one enrollment per student per course period
  @@unique([studentId, coursePeriodId])
  @@map("enrollments")
}

// Contribution - Individual payment from student for a specific course period and month
model Contribution {
  id               String        @id @default(cuid())
  studentId        String
  coursePeriodId   String
  month            Int           // 1-12 (month of the contribution)
  year             Int           // year of the contribution
  amount           Decimal       @db.Decimal(10, 2)
  concept          String        // description of payment
  paymentDate      DateTime      @default(now())
  paymentMethod    PaymentMethod @default(CASH)
  receipt          String?       // receipt number or reference
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Relations
  student       Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  coursePeriod  CoursePeriod  @relation(fields: [coursePeriodId], references: [id], onDelete: Cascade)

  // Unique constraint: one contribution per student per course period per month/year
  @@unique([studentId, coursePeriodId, month, year])
  @@map("contributions")
}

// CourseInvoice - Monthly invoice for course period
model CourseInvoice {
  id             String        @id @default(cuid())
  coursePeriodId String
  month          Int           // 1-12
  year           Int           // year
  totalAmount    Decimal       @db.Decimal(10, 2)
  dueDate        DateTime
  status         InvoiceStatus @default(PENDING)
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  coursePeriod CoursePeriod @relation(fields: [coursePeriodId], references: [id], onDelete: Cascade)

  // Unique constraint: one invoice per course period per month/year
  @@unique([coursePeriodId, month, year])
  @@map("course_invoices")
}

// Enums
enum EnrollmentStatus {
  ACTIVE
  SUSPENDED
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
  OTHER
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}
