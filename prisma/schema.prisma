// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// FASE 1: Authentication & Users
enum UserRole {
  ADMIN      // Secretaría - full access
  PRECEPTOR  // Preceptor - limited access
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // bcrypt hashed
  name      String
  role      UserRole @default(PRECEPTOR)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// FASE 2: Domain Models - Educational System

// Estudiante - Student information
model Estudiante {
  id        String   @id @default(cuid())
  dni       String   @unique
  nombre    String
  apellido  String
  email     String?  @unique
  telefono  String?
  direccion String?
  fechaNacimiento DateTime?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  matriculas Matricula[]
  aportes    Aporte[]

  @@map("estudiantes")
}

// Curso - Course definition
model Curso {
  id          String   @id @default(cuid())
  nombre      String
  descripcion String?
  duracion    Int      // duration in months
  precio      Decimal  @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  periodos CursoPeriodo[]

  @@map("cursos")
}

// CursoPeriodo - Course instance for a specific period
model CursoPeriodo {
  id           String   @id @default(cuid())
  cursoId      String
  nombre       String   // e.g., "Curso Básico - Marzo 2025"
  fechaInicio  DateTime
  fechaFin     DateTime
  precioMensual Decimal @db.Decimal(10, 2)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  curso      Curso       @relation(fields: [cursoId], references: [id], onDelete: Cascade)
  matriculas Matricula[]
  facturas   FacturaCurso[]

  @@map("curso_periodos")
}

// Matricula - Student enrollment in a course period
model Matricula {
  id             String   @id @default(cuid())
  estudianteId   String
  cursoPeriodoId String
  fechaMatricula DateTime @default(now())
  estado         EstadoMatricula @default(ACTIVA)
  observaciones  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  estudiante    Estudiante   @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
  cursoPeriodo  CursoPeriodo @relation(fields: [cursoPeriodoId], references: [id], onDelete: Cascade)

  // Unique constraint: one enrollment per student per course period
  @@unique([estudianteId, cursoPeriodoId])
  @@map("matriculas")
}

// Aporte - Individual payment from student
model Aporte {
  id           String      @id @default(cuid())
  estudianteId String
  monto        Decimal     @db.Decimal(10, 2)
  concepto     String      // description of payment
  fechaPago    DateTime    @default(now())
  metodoPago   MetodoPago  @default(EFECTIVO)
  comprobante  String?     // receipt number or reference
  observaciones String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // Relations
  estudiante Estudiante @relation(fields: [estudianteId], references: [id], onDelete: Cascade)

  @@map("aportes")
}

// FacturaCurso - Monthly invoice for course period
model FacturaCurso {
  id             String   @id @default(cuid())
  cursoPeriodoId String
  mes            Int      // 1-12
  anio           Int      // year
  montoTotal     Decimal  @db.Decimal(10, 2)
  fechaVencimiento DateTime
  estado         EstadoFactura @default(PENDIENTE)
  observaciones  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  cursoPeriodo CursoPeriodo @relation(fields: [cursoPeriodoId], references: [id], onDelete: Cascade)

  // Unique constraint: one invoice per course period per month/year
  @@unique([cursoPeriodoId, mes, anio])
  @@map("facturas_curso")
}

// Enums
enum EstadoMatricula {
  ACTIVA
  SUSPENDIDA
  FINALIZADA
  CANCELADA
}

enum MetodoPago {
  EFECTIVO
  TRANSFERENCIA
  TARJETA
  OTRO
}

enum EstadoFactura {
  PENDIENTE
  PAGADA
  VENCIDA
  CANCELADA
}
